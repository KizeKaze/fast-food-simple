<Files ".env">
  Order Allow,Deny
  Deny from all
</Files>

<Files "composer.json">
  Order Allow,Deny
  Deny from all
</Files>

<Files "composer.phar">
  Order Allow,Deny
  Deny from all
</Files>

<Files "composer.lock">
  Order Allow,Deny
  Deny from all
</Files>

<Files ".gitignore">
  Order Allow,Deny
  Deny from all
</Files>